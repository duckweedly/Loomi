{
  "name": "loomi-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:desktop-renderer": "vite --host 127.0.0.1 --port 5180 --strictPort",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "desktop:dev": "concurrently -k \"VITE_LOOMI_API_BASE_URL=${VITE_LOOMI_API_BASE_URL:-http://127.0.0.1:18080} bun run dev:desktop-renderer\" \"wait-on http://127.0.0.1:5180 && ELECTRON_START_URL=http://127.0.0.1:5180 electron .\"",
    "desktop:preview": "bun run build && electron ."
  },
  "dependencies": {
    "@lobehub/fluent-emoji": "latest",
    "@lobehub/icons": "latest",
    "@lobehub/ui": "latest",
    "animal-island-ui": "^0.9.4",
    "antd": "latest",
    "lucide-react": "latest",
    "motion": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "electron": "latest",
    "typescript": "latest",
    "vite": "latest",
    "wait-on": "latest"
  }
}
